<ui:FluentWindow
    x:Class="AutoHdrManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:AutoHdrManager.Views"
    Title="Auto HDR Manager"
    Width="1100"
    Height="720"
    MinWidth="800"
    MinHeight="500"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="TitleBar"
            Title="Auto HDR Manager"
            Grid.Row="0" />

        <ui:NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            OpenPaneLength="200">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="Dashboard"
                    TargetPageType="{x:Type views:DashboardPage}"
                    Icon="{ui:SymbolIcon Home24}" />
                <ui:NavigationViewItem
                    Content="Apply HDR"
                    TargetPageType="{x:Type views:ApplyPage}"
                    Icon="{ui:SymbolIcon DesktopFlow24}" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem
                    Content="Settings"
                    TargetPageType="{x:Type views:SettingsPage}"
                    Icon="{ui:SymbolIcon Settings24}" />
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>
    </Grid>

</ui:FluentWindow>
