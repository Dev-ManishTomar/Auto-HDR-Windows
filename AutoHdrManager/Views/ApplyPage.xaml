<Page
    x:Class="AutoHdrManager.Views.ApplyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="700" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Apply Auto HDR" FontSize="28" FontWeight="SemiBold" />
            <TextBlock
                Text="Select a game executable and configure Auto HDR settings"
                FontSize="13" Opacity="0.6" Margin="0,4,0,24" />

            <!-- Browse section -->
            <TextBlock Text="GAME EXECUTABLE" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,8" />
            <Border
                Padding="16"
                CornerRadius="8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBox
                        Grid.Column="0"
                        PlaceholderText="Enter path or browse..."
                        Text="{Binding ExePath, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,8,0" />

                    <ui:Button
                        Grid.Column="1"
                        Content="Browse"
                        Icon="{ui:SymbolIcon FolderOpen24}"
                        Command="{Binding BrowseCommand}" />
                </Grid>
            </Border>

            <!-- Existing entry info -->
            <Border
                Padding="12"
                CornerRadius="6"
                Margin="0,0,0,16"
                Visibility="{Binding ExistingEntryFound, Converter={StaticResource BoolToVisibility}}">
                <Border.Background>
                    <SolidColorBrush Color="#0088CC" Opacity="0.15" />
                </Border.Background>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Info24" Margin="0,0,8,0" FontSize="16" />
                    <TextBlock Text="{Binding ExistingInfo}" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Settings section -->
            <TextBlock Text="HDR SETTINGS" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="0,8,0,8" />
            <Border
                Padding="20"
                CornerRadius="8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                Margin="0,0,0,24">
                <StackPanel>

                    <!-- Auto HDR toggle -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Force Auto HDR" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock
                                Text="Override Direct3D to enable Auto HDR for this game"
                                FontSize="12" Opacity="0.5" Margin="0,2,0,0" />
                        </StackPanel>
                        <ui:ToggleSwitch
                            Grid.Column="1"
                            IsChecked="{Binding EnableAutoHdr}"
                            VerticalAlignment="Center" />
                    </Grid>

                    <Separator Opacity="0.15" Margin="0,0,0,16" />

                    <!-- 10-bit toggle -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Enable 10-bit" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock
                                Text="Upgrade buffers to 10-bit for richer color depth"
                                FontSize="12" Opacity="0.5" Margin="0,2,0,0" />
                        </StackPanel>
                        <ui:ToggleSwitch
                            Grid.Column="1"
                            IsChecked="{Binding Enable10Bit}"
                            IsEnabled="{Binding EnableAutoHdr}"
                            VerticalAlignment="Center" />
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Action buttons -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Button
                    Grid.Column="0"
                    Content="Apply Changes"
                    Appearance="Primary"
                    Icon="{ui:SymbolIcon Checkmark24}"
                    Command="{Binding ApplyCommand}"
                    Padding="16,8"
                    Margin="0,0,8,0" />

                <ui:Button
                    Grid.Column="1"
                    Content="Remove All"
                    Appearance="Danger"
                    Icon="{ui:SymbolIcon Delete24}"
                    Command="{Binding RemoveAllCommand}"
                    Padding="16,8"
                    Visibility="{Binding ExistingEntryFound, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <!-- Status message -->
            <Border
                Padding="12"
                CornerRadius="6"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background">
                            <Setter.Value>
                                <SolidColorBrush Color="#CC3333" Opacity="0.15" />
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#00CC66" Opacity="0.15" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Margin="0,0,8,0" FontSize="16">
                        <ui:SymbolIcon.Style>
                            <Style TargetType="ui:SymbolIcon">
                                <Setter Property="Symbol" Value="DismissCircle24" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                        <Setter Property="Symbol" Value="CheckmarkCircle24" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:SymbolIcon.Style>
                    </ui:SymbolIcon>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</Page>
